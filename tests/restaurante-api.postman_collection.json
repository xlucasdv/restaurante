    {
      "name": "01 - Autenticação",
      "item": [
        {
          "name": "Login - Gerente (Sucesso)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token is present\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.token).to.exist;",
                  "    pm.environment.set(\"token_gerente\", jsonData.token);",
                  "    pm.environment.set(\"usuario_id\", jsonData.usuario.id);",
                  "});",
                  "",
                  "pm.test(\"Response has usuario data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.usuario).to.have.property('email');",
                  "    pm.expect(jsonData.usuario.perfil).to.eql('GERENTE');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"gerente@teste.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            },
            "description": "Login de gerente para obter token JWT"
          },
          "response": []
        },
